# Google OAuth Configuration
# Create these at: https://console.cloud.google.com/apis/credentials
# Project: amplifier-portal (create new)
# OAuth 2.0 Client ID type: Web application
# Authorized redirect URIs: https://amplify.elelem.expert/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth Configuration
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://amplify.elelem.expert

# Email Domain Allowlist
# Comma-separated list of allowed email domains (without @)
ALLOWED_EMAIL_DOMAINS=trilogy.com

# Individual Email Allowlist (optional)
# Comma-separated list of specific emails allowed in addition to domains
ALLOWED_EMAILS=david.proctor@trilogy.com
