{
  "manifest_version": 3,
  "name": "Amplifier — Substack Cookie Sync",
  "version": "1.0.0",
  "description": "One-click sync your Substack session to Amplifier",
  "permissions": ["cookies", "activeTab", "storage"],
  "host_permissions": [
    "https://*.substack.com/*",
    "https://amplify.elelem.expert/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
